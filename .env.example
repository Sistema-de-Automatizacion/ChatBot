# Plantilla de variables de entorno para desarrollo local.
# Copia este archivo como `.env` en la raiz del repo:
#   cp .env.example .env
# Luego reemplaza los valores CHANGE_ME con los reales.
# El archivo `.env` esta ignorado por git, asi que no sube al repo.

# ----------------------------------------------------------------------
# Base de datos (MySQL en Azure)
# ----------------------------------------------------------------------
# Para desarrollo local conectamos contra la BD de pruebas. Las credenciales
# reales las tiene el equipo; pidelas por el canal interno.
DB_URL=jdbc:mysql://HOST:3306/DATABASE?useSSL=true&requireSSL=true&verifyServerCertificate=true&serverTimezone=UTC
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME

# ----------------------------------------------------------------------
# Seguridad
# ----------------------------------------------------------------------
# Token compartido que protege /api/** (header X-API-Key). n8n debe enviar este
# mismo valor en cada llamada al endpoint del bot. Para local podes usar
# cualquier string; en produccion debe ser >= 32 chars random.
APP_API_KEY=local-dev-key-1234
